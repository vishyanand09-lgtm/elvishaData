<script>
/* ── MINI CHART BUILD ── */
const bars = [30,42,38,55,48,62,45,70,58,85,72,100];
const mc = document.getElementById('mini-chart');
bars.forEach((h, i) => {
  const b = document.createElement('div');
  b.className = 'mbar' + (i === bars.length-1 ? ' hi' : '');
  b.style.height = h + '%';
  b.style.animationDelay = (i * 0.05) + 's';
  mc.appendChild(b);
});

/* ── SCROLL REVEAL ── */
const observer = new IntersectionObserver(entries => {
  entries.forEach(e => {
    if (e.isIntersecting) {
      e.target.classList.add('visible');
      observer.unobserve(e.target);
    }
  });
}, { threshold: 0.12 });
document.querySelectorAll('.reveal').forEach(el => observer.observe(el));

/* ── FAQ TOGGLE ── */
function toggleFaq(btn) {
  const item = btn.closest('.faq-item');
  const isOpen = item.classList.contains('open');
  document.querySelectorAll('.faq-item').forEach(i => i.classList.remove('open'));
  if (!isOpen) item.classList.add('open');
}

/* ── MOBILE NAV ── */
const burger = document.getElementById('burger');
const navLinks = document.getElementById('nav-links');
burger.addEventListener('click', () => {
  navLinks.classList.toggle('open');
});

/* ── EMAIL SUBMIT ── */
function submitEmail() {
  const email = document.getElementById('email-input').value;
  const note = document.getElementById('cta-note');
  if (!email || !email.includes('@')) {
    document.getElementById('email-input').style.borderColor = '#F43F5E';
    return;
  }
  note.innerHTML = '✅ Terima kasih! Kami akan menghubungi kamu dalam 24 jam.';
  note.style.color = '#A3E635';
  document.getElementById('email-input').value = '';
}

/* ── NAV SCROLL EFFECT ── */
window.addEventListener('scroll', () => {
  const nav = document.getElementById('nav');
  nav.style.background = window.scrollY > 60
    ? 'rgba(9,17,28,.98)'
    : 'rgba(9,17,28,.9)';
});

/* ── SMOOTH ANCHOR ── */
document.querySelectorAll('a[href^="#"]').forEach(a => {
  a.addEventListener('click', e => {
    e.preventDefault();
    navLinks.classList.remove('open');
    const target = document.querySelector(a.getAttribute('href'));
    if (target) target.scrollIntoView({ behavior: 'smooth', block: 'start' });
  });
});
</script>
