<!DOCTYPE html>
<html lang="id">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Elvisha — Your Personal Business Intelligence </title>
<meta name="description" content="Agency data intelligence Indonesia. Dashboard penjualan, sales forecasting, untuk perusahaan anda.">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=Inter:wght@300;400;500;600&family=DM+Mono:wght@400;500&display=swap" rel="stylesheet">
<style>
/* ════════════════════════════════════════════════
   TOKENS
════════════════════════════════════════════════ */
:root {
  --ink:     #09111C;
  --ink2:    #111D2E;
  --slate:   #1E3A5F;
  --teal:    #0EA5C8;
  --tealL:   #67E8F9;
  --tealXL:  #CFFAFE;
  --lime:    #A3E635;
  --limeD:   #65A30D;
  --white:   #FFFFFF;
  --fog:     #F0F5FA;
  --mist:    #E2EAF4;
  --ghost:   #7B90A8;
  --body:    #334155;

  --ff-head: 'Syne', sans-serif;
  --ff-body: 'Inter', sans-serif;
  --ff-mono: 'DM Mono', monospace;

  --max:     1160px;
  --r:       16px;
}

/* ════════════════════════════════════════════════
   RESET + BASE
════════════════════════════════════════════════ */
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
html { scroll-behavior: smooth; }
body {
  font-family: var(--ff-body);
  background: var(--white);
  color: var(--body);
  line-height: 1.6;
  -webkit-font-smoothing: antialiased;
}
img { display: block; max-width: 100%; }
a  { text-decoration: none; color: inherit; }
ul { list-style: none; }

/* ════════════════════════════════════════════════
   UTILITIES
════════════════════════════════════════════════ */
.container { max-width: var(--max); margin: 0 auto; padding: 0 28px; }
.tag {
  display: inline-block;
  font-family: var(--ff-mono);
  font-size: 11px; font-weight: 500;
  letter-spacing: .06em; text-transform: uppercase;
  padding: 5px 14px; border-radius: 20px;
}
.tag-teal  { background: rgba(14,165,200,.12); color: var(--teal); border: 1px solid rgba(14,165,200,.25); }
.tag-lime  { background: rgba(163,230,53,.12); color: var(--limeD); border: 1px solid rgba(163,230,53,.3); }
.tag-ghost { background: var(--fog); color: var(--ghost); border: 1px solid var(--mist); }
.sr-only   { position: absolute; width: 1px; height: 1px; clip: rect(0,0,0,0); overflow: hidden; }

/* ════════════════════════════════════════════════
   NAV
════════════════════════════════════════════════ */
.nav {
  position: fixed; top: 0; left: 0; right: 0; z-index: 100;
  padding: 0 28px; height: 60px;
  display: flex; align-items: center; justify-content: space-between;
  background: rgba(9,17,28,.9);
  backdrop-filter: blur(16px);
  border-bottom: 1px solid rgba(255,255,255,.06);
  transition: background .3s;
}
.nav-logo {
  display: flex; align-items: center; gap: 10px;
  font-family: var(--ff-head); font-weight: 700;
  font-size: 17px; color: var(--white);
  letter-spacing: -.4px;
}
.nav-mark {
  width: 30px; height: 30px;
  background: linear-gradient(135deg, var(--teal), #0369A1);
  border-radius: 8px;
  display: grid; place-items: center;
}
.nav-mark svg { width: 16px; height: 16px; }
.nav-mark span { color: var(--tealL); font-size: 13px; }
.nav-links {
  display: flex; align-items: center; gap: 32px;
}
.nav-links a {
  font-size: 13px; font-weight: 500; color: var(--ghost);
  transition: color .2s;
}
.nav-links a:hover { color: var(--white); }
.nav-cta {
  background: var(--teal); color: var(--white);
  padding: 8px 20px; border-radius: 8px;
  font-size: 13px; font-weight: 600;
  transition: background .2s, transform .15s;
}
.nav-cta:hover { background: var(--tealL); color: var(--ink); transform: translateY(-1px); }
.nav-burger { display: none; flex-direction: column; gap: 5px; cursor: pointer; padding: 4px; }
.nav-burger span { display: block; width: 22px; height: 2px; background: var(--white); border-radius: 2px; transition: all .3s; }

/* ════════════════════════════════════════════════
   HERO
════════════════════════════════════════════════ */
.hero {
  min-height: 100vh;
  background: var(--ink);
  display: flex; flex-direction: column; justify-content: center;
  padding: 100px 28px 80px;
  position: relative; overflow: hidden;
}

/* Animated grid background */
.hero-grid {
  position: absolute; inset: 0; pointer-events: none;
  background-image:
    linear-gradient(rgba(14,165,200,.04) 1px, transparent 1px),
    linear-gradient(90deg, rgba(14,165,200,.04) 1px, transparent 1px);
  background-size: 60px 60px;
  animation: gridDrift 20s linear infinite;
}
@keyframes gridDrift { from { transform: translateY(0); } to { transform: translateY(60px); } }

/* Glow orbs */
.hero-orb {
  position: absolute; border-radius: 50%; filter: blur(80px);
  pointer-events: none; animation: orbFloat 8s ease-in-out infinite;
}
.hero-orb-1 { width: 500px; height: 500px; background: rgba(14,165,200,.08); top: -100px; right: -100px; }
.hero-orb-2 { width: 300px; height: 300px; background: rgba(163,230,53,.06); bottom: 0; left: 10%; animation-delay: -4s; }
@keyframes orbFloat { 0%,100%{transform:translateY(0)} 50%{transform:translateY(-30px)} }

.hero-inner {
  position: relative; z-index: 1;
  max-width: var(--max); margin: 0 auto; width: 100%;
  display: grid; grid-template-columns: 1fr 1fr; gap: 60px; align-items: center;
}

/* Eyebrow */
.hero-eyebrow {
  display: flex; align-items: center; gap: 10px; margin-bottom: 24px;
}
.hero-eyebrow-line { width: 32px; height: 2px; background: var(--teal); }

/* Headline — the signature element: large split type with teal underline stroke */
.hero-h1 {
  font-family: var(--ff-head);
  font-size: clamp(38px, 5vw, 62px);
  font-weight: 800;
  line-height: 1.05;
  letter-spacing: -.03em;
  color: var(--white);
  margin-bottom: 24px;
}
.hero-h1 .stroke {
  -webkit-text-stroke: 2px var(--teal);
  color: transparent;
  display: block;
}
.hero-h1 .solid { display: block; }

.hero-body {
  font-size: 16px; line-height: 1.7;
  color: var(--ghost); margin-bottom: 36px;
  max-width: 440px;
}

.hero-actions { display: flex; gap: 14px; flex-wrap: wrap; }
.btn-primary {
  background: var(--teal); color: var(--white);
  padding: 14px 28px; border-radius: 10px;
  font-size: 14px; font-weight: 600;
  display: flex; align-items: center; gap: 8px;
  transition: all .2s; border: none; cursor: pointer; font-family: inherit;
}
.btn-primary:hover { background: #0BBBD8; transform: translateY(-2px); box-shadow: 0 12px 32px rgba(14,165,200,.3); }
.btn-outline {
  background: transparent; color: var(--white);
  padding: 14px 28px; border-radius: 10px;
  font-size: 14px; font-weight: 600;
  border: 1.5px solid rgba(255,255,255,.18);
  display: flex; align-items: center; gap: 8px;
  transition: all .2s; cursor: pointer; font-family: inherit;
}
.btn-outline:hover { border-color: var(--teal); color: var(--teal); }

/* Hero stats */
.hero-stats {
  display: flex; gap: 28px; margin-top: 48px; padding-top: 32px;
  border-top: 1px solid rgba(255,255,255,.08);
}
.hero-stat .n {
  font-family: var(--ff-head); font-size: 28px; font-weight: 800;
  color: var(--white); letter-spacing: -.03em;
}
.hero-stat .n span { color: var(--teal); }
.hero-stat .l { font-size: 11px; color: var(--ghost); margin-top: 2px; text-transform: uppercase; letter-spacing: .08em; }

/* Hero right: live dashboard preview */
.hero-preview {
  background: rgba(255,255,255,.04);
  border: 1px solid rgba(255,255,255,.08);
  border-radius: 20px;
  padding: 20px;
  backdrop-filter: blur(10px);
  position: relative;
}
.preview-bar {
  display: flex; align-items: center; gap: 6px; margin-bottom: 16px;
}
.preview-dot { width: 10px; height: 10px; border-radius: 50%; }
.preview-title {
  margin-left: 8px;
  font-family: var(--ff-mono); font-size: 11px; color: var(--ghost);
}
.preview-kpis {
  display: grid; grid-template-columns: 1fr 1fr; gap: 10px; margin-bottom: 14px;
}
.pkpi {
  background: rgba(255,255,255,.05); border-radius: 10px;
  padding: 14px 16px; border: 1px solid rgba(255,255,255,.06);
}
.pkpi-val {
  font-family: var(--ff-head); font-size: 20px; font-weight: 800;
  color: var(--white); letter-spacing: -.04em;
}
.pkpi-lbl { font-size: 10px; color: var(--ghost); margin-top: 3px; }
.pkpi-trend { font-size: 10px; font-weight: 600; margin-top: 6px; }
.pkpi-trend.up { color: var(--lime); }
.pkpi-trend.dn { color: #F43F5E; }

/* Mini chart bars */
.mini-chart { display: flex; align-items: flex-end; gap: 3px; height: 48px; margin-top: 14px; }
.mbar {
  flex: 1; border-radius: 3px 3px 0 0;
  background: rgba(14,165,200,.35);
  transition: height .8s ease;
  animation: barGrow .8s ease forwards;
}
.mbar.hi { background: var(--teal); }
@keyframes barGrow { from { height: 0 !important; } }

/* Tax calendar mini */
.mini-tax { margin-top: 14px; }
.mini-tax-row {
  display: flex; justify-content: space-between; align-items: center;
  padding: 7px 0; border-bottom: 1px solid rgba(255,255,255,.05);
  font-size: 11px;
}
.mini-tax-row:last-child { border: none; }
.mini-tax-row .ttype {
  padding: 2px 8px; border-radius: 10px; font-size: 10px; font-weight: 600;
}
.tx-ppn  { background: rgba(124,58,237,.2); color: #C4B5FD; }
.tx-pph  { background: rgba(239,68,68,.15); color: #FCA5A5; }
.mini-tax-row .tamt { font-family: var(--ff-mono); font-size: 10px; color: #F43F5E; }
.mini-tax-row .tdate { color: var(--ghost); }

/* Floating badge */
.preview-badge {
  position: absolute; top: -14px; right: 20px;
  background: var(--lime); color: var(--ink);
  font-size: 10px; font-weight: 700; font-family: var(--ff-mono);
  padding: 4px 12px; border-radius: 20px;
  letter-spacing: .06em; text-transform: uppercase;
}

/* ════════════════════════════════════════════════
   LOGO BAR
════════════════════════════════════════════════ */
.logobar {
  background: var(--fog);
  padding: 24px 28px;
  border-top: 1px solid var(--mist);
  border-bottom: 1px solid var(--mist);
}
.logobar-inner {
  max-width: var(--max); margin: 0 auto;
  display: flex; align-items: center; gap: 40px; flex-wrap: wrap;
  justify-content: center;
}
.logobar-label {
  font-size: 11px; color: var(--ghost); text-transform: uppercase;
  letter-spacing: .1em; white-space: nowrap;
}
.logobar-logos { display: flex; gap: 36px; align-items: center; flex-wrap: wrap; justify-content: center; }
.logobar-logo {
  font-family: var(--ff-head); font-size: 14px; font-weight: 700;
  color: #CBD5E1; letter-spacing: -.02em;
  transition: color .2s;
}
.logobar-logo:hover { color: var(--body); }

/* ════════════════════════════════════════════════
   SERVICES
════════════════════════════════════════════════ */
.services { padding: 100px 28px; background: var(--white); }
.section-eye {
  display: flex; align-items: center; gap: 12px; margin-bottom: 16px;
}
.section-h {
  font-family: var(--ff-head);
  font-size: clamp(28px, 4vw, 44px);
  font-weight: 800; letter-spacing: -.03em;
  color: var(--ink); line-height: 1.1;
  margin-bottom: 16px;
}
.section-h span { color: var(--teal); }
.section-sub {
  font-size: 16px; color: var(--ghost); max-width: 520px; line-height: 1.7;
}

.services-header { margin-bottom: 60px; }

.services-grid {
  display: grid; grid-template-columns: repeat(2, 1fr); gap: 24px;
}
.svc-card {
  border: 1.5px solid var(--mist); border-radius: 20px;
  padding: 36px 32px;
  position: relative; overflow: hidden;
  transition: border-color .25s, transform .25s, box-shadow .25s;
  background: white;
}
.svc-card::before {
  content: '';
  position: absolute; inset: 0;
  background: linear-gradient(135deg, rgba(14,165,200,.04) 0%, transparent 60%);
  opacity: 0; transition: opacity .3s;
}
.svc-card:hover { border-color: var(--teal); transform: translateY(-4px); box-shadow: 0 20px 48px rgba(14,165,200,.1); }
.svc-card:hover::before { opacity: 1; }

/* Large card spans 2 cols */
.svc-card.wide { grid-column: span 2; display: grid; grid-template-columns: 1fr 1fr; gap: 40px; align-items: center; }

.svc-icon {
  width: 52px; height: 52px; border-radius: 14px;
  display: grid; place-items: center; font-size: 24px;
  margin-bottom: 24px;
}
.svc-icon.teal  { background: rgba(14,165,200,.1); }
.svc-icon.lime  { background: rgba(163,230,53,.1); }
.svc-icon.amber { background: rgba(245,158,11,.1); }
.svc-icon.purple{ background: rgba(124,58,237,.1); }

.svc-tag { margin-bottom: 14px; }
.svc-h {
  font-family: var(--ff-head); font-size: 22px; font-weight: 700;
  color: var(--ink); letter-spacing: -.02em; margin-bottom: 12px;
}
.svc-body { font-size: 14px; color: var(--ghost); line-height: 1.7; margin-bottom: 20px; }

.svc-features { display: flex; flex-direction: column; gap: 8px; }
.svc-feat {
  display: flex; align-items: center; gap: 10px;
  font-size: 13px; color: var(--body);
}
.svc-feat::before {
  content: '';
  width: 6px; height: 6px; border-radius: 50%;
  background: var(--teal); flex-shrink: 0;
}

.svc-price {
  margin-top: 28px; padding-top: 20px;
  border-top: 1px solid var(--mist);
  display: flex; align-items: center; justify-content: space-between;
}
.svc-price-val {
  font-family: var(--ff-head); font-size: 18px; font-weight: 700;
  color: var(--ink); letter-spacing: -.02em;
}
.svc-price-val span { font-size: 13px; color: var(--ghost); font-family: var(--ff-body); font-weight: 400; }
.svc-link {
  font-size: 13px; font-weight: 600; color: var(--teal);
  display: flex; align-items: center; gap: 6px;
  transition: gap .2s;
}
.svc-link:hover { gap: 10px; }

/* Viz card right side: mini dashboard mockup */
.svc-mockup {
  background: var(--ink);
  border-radius: 14px;
  padding: 18px;
  overflow: hidden;
}
.mock-header { display: flex; gap: 5px; margin-bottom: 14px; }
.mock-dot { width: 9px; height: 9px; border-radius: 50%; }
.mock-kpis { display: grid; grid-template-columns: 1fr 1fr; gap: 8px; margin-bottom: 12px; }
.mock-kpi {
  background: rgba(255,255,255,.06); border-radius: 8px; padding: 10px 12px;
}
.mock-kpi-val { font-family: var(--ff-head); font-size: 16px; font-weight: 800; color: white; }
.mock-kpi-lbl { font-size: 9px; color: var(--ghost); margin-top: 2px; }
.mock-bars { display: flex; align-items: flex-end; gap: 3px; height: 40px; }
.mock-bar { flex: 1; border-radius: 2px 2px 0 0; }
.mock-line {
  height: 1px; background: rgba(255,255,255,.06);
  margin: 10px 0;
}
.mock-pills { display: flex; gap: 6px; flex-wrap: wrap; }
.mock-pill {
  padding: 3px 10px; border-radius: 20px; font-size: 9px; font-weight: 600;
}

/* ════════════════════════════════════════════════
   HOW IT WORKS
════════════════════════════════════════════════ */
.how {
  padding: 100px 28px;
  background: var(--ink);
  position: relative; overflow: hidden;
}
.how::before {
  content: '';
  position: absolute; inset: 0;
  background-image: radial-gradient(rgba(14,165,200,.06) 1px, transparent 1px);
  background-size: 32px 32px;
}
.how .section-h { color: var(--white); }
.how .section-sub { color: var(--ghost); }

.how-steps {
  display: grid; grid-template-columns: repeat(4, 1fr);
  gap: 2px; margin-top: 60px;
  position: relative; z-index: 1;
}

/* Connecting line between steps */
.how-steps::before {
  content: '';
  position: absolute;
  top: 32px; left: calc(12.5%); right: calc(12.5%);
  height: 1px; background: linear-gradient(90deg, transparent, var(--teal), transparent);
  z-index: 0;
}

.step {
  text-align: center; padding: 0 20px;
  position: relative; z-index: 1;
}
.step-num {
  width: 64px; height: 64px; border-radius: 50%;
  border: 1.5px solid rgba(14,165,200,.3);
  background: rgba(14,165,200,.08);
  display: grid; place-items: center; margin: 0 auto 24px;
  font-family: var(--ff-mono); font-size: 13px; font-weight: 500;
  color: var(--teal);
  position: relative;
  transition: all .3s;
}
.step:hover .step-num {
  background: var(--teal); color: var(--ink); border-color: var(--teal);
  box-shadow: 0 0 32px rgba(14,165,200,.4);
}
.step-icon { font-size: 22px; margin-bottom: 16px; }
.step-h {
  font-family: var(--ff-head); font-size: 16px; font-weight: 700;
  color: var(--white); margin-bottom: 10px;
}
.step-body { font-size: 13px; color: var(--ghost); line-height: 1.6; }

/* ════════════════════════════════════════════════
   RESULTS / PROOF
════════════════════════════════════════════════ */
.results { padding: 100px 28px; background: var(--fog); }
.results-grid {
  display: grid; grid-template-columns: repeat(3, 1fr); gap: 24px;
  margin-top: 60px;
}
.result-card {
  background: white; border-radius: 20px; padding: 36px 32px;
  border: 1.5px solid var(--mist);
  transition: transform .25s, box-shadow .25s;
}
.result-card:hover { transform: translateY(-4px); box-shadow: 0 20px 48px rgba(0,0,0,.06); }
.result-num {
  font-family: var(--ff-head); font-size: 48px; font-weight: 800;
  letter-spacing: -.04em; line-height: 1;
  background: linear-gradient(135deg, var(--teal), var(--lime));
  -webkit-background-clip: text; -webkit-text-fill-color: transparent;
  margin-bottom: 8px;
}
.result-label { font-size: 16px; font-weight: 600; color: var(--ink); margin-bottom: 10px; }
.result-desc  { font-size: 13px; color: var(--ghost); line-height: 1.6; }

/* ════════════════════════════════════════════════
   TECH STACK
════════════════════════════════════════════════ */
.tech { padding: 80px 28px; background: white; }
.tech-grid {
  display: flex; flex-wrap: wrap; gap: 12px;
  margin-top: 40px; justify-content: center;
}
.tech-chip {
  display: flex; align-items: center; gap: 8px;
  padding: 10px 18px; border-radius: 40px;
  border: 1.5px solid var(--mist);
  font-size: 13px; font-weight: 500; color: var(--body);
  transition: all .2s;
}
.tech-chip:hover { border-color: var(--teal); color: var(--teal); transform: translateY(-2px); }
.tech-chip .dot { width: 8px; height: 8px; border-radius: 50%; flex-shrink: 0; }

/* ════════════════════════════════════════════════
   PRICING
════════════════════════════════════════════════ */
.pricing { padding: 100px 28px; background: var(--fog); }
.pricing-grid {
  display: grid; grid-template-columns: repeat(3, 1fr);
  gap: 24px; margin-top: 60px;
}
.price-card {
  background: white; border-radius: 20px; padding: 36px 32px;
  border: 1.5px solid var(--mist);
  position: relative; overflow: hidden;
  transition: transform .25s, box-shadow .25s;
  display: flex; flex-direction: column;
}
.price-card:hover { transform: translateY(-4px); box-shadow: 0 24px 64px rgba(0,0,0,.08); }
.price-card.featured {
  border-color: var(--teal);
  background: var(--ink);
}
.price-card.featured::before {
  content: '';
  position: absolute; inset: 0;
  background: linear-gradient(135deg, rgba(14,165,200,.08) 0%, transparent 60%);
}

.price-rec {
  position: absolute; top: -1px; right: 24px;
  background: var(--lime); color: var(--ink);
  font-size: 10px; font-weight: 700; font-family: var(--ff-mono);
  padding: 5px 14px; border-radius: 0 0 10px 10px; letter-spacing: .06em;
}
.price-name {
  font-family: var(--ff-head); font-size: 14px; font-weight: 700;
  text-transform: uppercase; letter-spacing: .1em;
  color: var(--ghost); margin-bottom: 20px;
}
.price-card.featured .price-name { color: var(--tealL); }
.price-val {
  font-family: var(--ff-head); font-size: 38px; font-weight: 800;
  color: var(--ink); letter-spacing: -.04em; line-height: 1;
  margin-bottom: 6px;
}
.price-card.featured .price-val { color: var(--white); }
.price-period { font-size: 13px; color: var(--ghost); margin-bottom: 28px; }
.price-divider { height: 1px; background: var(--mist); margin-bottom: 24px; }
.price-card.featured .price-divider { background: rgba(255,255,255,.1); }

.price-features { display: flex; flex-direction: column; gap: 12px; flex: 1; }
.price-feat {
  display: flex; align-items: flex-start; gap: 10px;
  font-size: 13px; color: var(--body); line-height: 1.5;
}
.price-card.featured .price-feat { color: rgba(255,255,255,.75); }
.pf-icon { flex-shrink: 0; margin-top: 2px; font-size: 14px; }

.price-cta {
  display: block; text-align: center;
  margin-top: 28px; padding: 13px;
  border-radius: 10px; font-size: 14px; font-weight: 600;
  border: 1.5px solid var(--mist);
